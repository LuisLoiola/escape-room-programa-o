#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int porta1() {
    int resposta, tentativas = 0;
    int correto = 42;

    printf("\n========================================\n");
    printf("       PORTA 1: Camara Matematica       \n");
    printf("========================================\n");
    printf("Uma equacao esta gravada na pedra da porta.\n");
    printf("Resolva-a para continuar.\n\n");
    printf("  15 + 27 = ?   (3 tentativas)\n\n");

    while (tentativas < 3) {
        printf("Tentativa %d/3: ", tentativas + 1);
        scanf("%d", &resposta);
        tentativas++;

        if (resposta == correto) {
            printf("\n>>> A porta range e se abre! Voce avanca. <<<\n");
            return 1;
        } else {
            printf("Errado. ");
            if (tentativas < 3) printf("Tente novamente.\n");
        }
    }

    printf("\n>>> Sem tentativas. A porta trava. <<<\n");
    return 0;
}

int porta2() {
    int chute, secreto, tentativas = 0;

    srand(time(NULL));
    secreto = rand() % 20 + 1;

    printf("\n========================================\n");
    printf("     PORTA 2: Sala do Numero Secreto    \n");
    printf("========================================\n");
    printf("Um cofre com numeros bloqueia a passagem.\n");
    printf("Descubra o numero entre 1 e 20.  (5 tentativas)\n\n");

    while (tentativas < 5) {
        printf("Tentativa %d/5: ", tentativas + 1);
        scanf("%d", &chute);
        tentativas++;

        if (chute < secreto) printf("Muito baixo...\n");
        else if (chute > secreto) printf("Muito alto...\n");
        else {
            printf("\n>>> Clique! O cofre abre. Voce passa! <<<\n");
            return 1;
        }
    }

    printf("\n>>> Tentativas esgotadas. O numero era %d. <<<\n", secreto);
    return 0;
}

int porta3() {
    int resposta, tentativas = 0;

    printf("\n========================================\n");
    printf("        PORTA 3: Porta do Enigma        \n");
    printf("========================================\n");
    printf("Palavras aparecem flutuando no ar:\n\n");
    printf("  'Sou par. Estou entre 10 e 20.\n");
    printf("   Sou divisivel por 3.\n");
    printf("   Diga meu nome e sera livre.'\n\n");
    printf("  (2 tentativas)\n\n");

    while (tentativas < 2) {
        printf("Tentativa %d/2: ", tentativas + 1);
        scanf("%d", &resposta);
        tentativas++;

        if (resposta == 12 || resposta == 18) {
            printf("\n>>> A porta explode de luz. VOCE ESCAPOU! <<<\n");
            return 1;
        } else {
            printf("Errado. ");
            if (tentativas < 2) printf("Uma ultima chance...\n");
        }
    }

    printf("\n>>> Falhou. (respostas validas: 12 ou 18) <<<\n");
    return 0;
}

void placar(int p1, int p2, int p3) {
    int total = p1 + p2 + p3;
    printf("========================================\n");
    printf("             RESULTADO FINAL            \n");
    printf("========================================\n");
    printf("  Porta Matematica:   %s\n", p1 ? "ABERTA  [+1 ponto]" : "fechada [0 pontos]");
    printf("  Numero Secreto:     %s\n", p2 ? "ABERTA  [+1 ponto]" : "fechada [0 pontos]");
    printf("  Porta do Enigma:    %s\n", p3 ? "ABERTA  [+1 ponto]" : "fechada [0 pontos]");
    printf("----------------------------------------\n");
    printf("  PONTUACAO FINAL: %d/3\n", total);
    printf("----------------------------------------\n");

    if (total == 3) {
        printf("  STATUS: FUGA COMPLETA! Genio!\n");
    } else if (total == 2) {
        printf("  STATUS: Quase la... Tente de novo!\n");
    } else if (total == 1) {
        printf("  STATUS: A sala venceu desta vez.\n");
    } else {
        printf("  STATUS: A escuridao te engoliu.\n");
    }
    printf("========================================\n");
}

int main() {
    int escolha;
    int abertas = 0;
    int p1 = 0, p2 = 0, p3 = 0;

    printf("========================================\n");
    printf("        BEM-VINDO AO ESCAPE ROOM        \n");
    printf("========================================\n");
    printf("Voce acorda em uma sala escura.\n");
    printf("Tres portas bloqueiam sua saida.\n");
    printf("Resolva os desafios e escape!\n\n");

    do {
        printf("--- PORTAS ---\n");
        printf("1 - Porta Matematica  [%s]\n", p1 ? "ABERTA" : "fechada");
        printf("2 - Numero Secreto    [%s]\n", p2 ? "ABERTA" : "fechada");
        printf("3 - Porta do Enigma   [%s]\n", p3 ? "ABERTA" : "fechada");
        printf("0 - Desistir\n\n");
        printf("Portas abertas: %d/3\n", abertas);
        printf("Escolha: ");
        scanf("%d", &escolha);

        if (escolha == 1 && !p1) { p1 = porta1(); if (p1) abertas++; }
        else if (escolha == 2 && !p2) { p2 = porta2(); if (p2) abertas++; }
        else if (escolha == 3 && !p3) { p3 = porta3(); if (p3) abertas++; }
        else if ((escolha >= 1 && escolha <= 3)) printf("\nEsta porta ja foi tentada!\n");
        else if (escolha == 0) printf("\nVoce desistiu...\n");
        else printf("\nOpcao invalida!\n");

        printf("\n");

        if (abertas == 3) {
            printf("========================================\n");
            printf("   PARABENS! VOCE ESCAPOU DA SALA!     \n");
            printf("========================================\n\n");
            break;
        }

    } while (escolha != 0);

    placar(p1, p2, p3);

    return 0;
}
