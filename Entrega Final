#include <stdio.h>
#include <stdlib.h>
#include <time.h>

void porta1() {
    int resposta;
    int correto = 42;

    printf("\n--- PORTA 1: Camara Matematica ---\n");
    printf("Para abrir esta porta, resolva:\n");
    printf("  15 + 27 = ?\n");
    printf("Sua resposta: ");
    scanf("%d", &resposta);

    if (resposta == correto) {
        printf("Correto! A porta se abre com um estrondo!\n");
    } else {
        printf("Errado! A porta permanece fechada.\n");
        printf("(resposta correta era %d)\n", correto);
    }
}

void porta2() {
    int chute, secreto;

    srand(time(NULL));
    secreto = rand() % 20 + 1;

    printf("\n--- PORTA 2: Sala do Numero Secreto ---\n");
    printf("Ha um numero entre 1 e 20 gravado na porta.\n");
    printf("Descubra qual e para abri-la!\n\n");

    do {
        printf("Seu chute: ");
        scanf("%d", &chute);

        if (chute < secreto) {
            printf("Muito baixo! Tente mais alto.\n");
        } else if (chute > secreto) {
            printf("Muito alto! Tente mais baixo.\n");
        } else {
            printf("Isso! A porta range e se abre!\n");
        }
    } while (chute != secreto);
}

void porta3() {
    int resposta;

    printf("\n--- PORTA 3: Porta do Enigma ---\n");
    printf("Uma inscricao na parede diz:\n\n");
    printf("  'Sou par, estou entre 10 e 20,\n");
    printf("   e sou divisivel por 3.\n");
    printf("   Qual numero sou eu?'\n\n");
    printf("Sua resposta: ");
    scanf("%d", &resposta);

    if (resposta == 12 || resposta == 18) {
        printf("A porta treme... e se abre lentamente!\n");
        printf("Voce escapou! PARABENS!\n");
    } else {
        printf("Errado. A porta nao se move.\n");
        printf("(dica: existem dois numeros possiveis)\n");
    }
}

int main() {
    int escolha;

    printf("========================================\n");
    printf("        BEM-VINDO AO ESCAPE ROOM        \n");
    printf("========================================\n");
    printf("Voce acorda em uma sala escura...\n");
    printf("Mas voce tem algumas opcoes para escapar...\n\n");

    do {
        printf("Escolha uma porta:\n");
        printf("1 - Porta Matematica\n");
        printf("2 - Porta do Numero Secreto\n");
        printf("3 - Porta do Enigma\n");
        printf("0 - Sair\n\n");
        printf("Sua escolha: ");
        scanf("%d", &escolha);

        if (escolha == 1) {
            porta1();
        } else if (escolha == 2) {
            porta2();
        } else if (escolha == 3) {
            porta3();
        } else if (escolha == 0) {
            printf("\nVoce desistiu. A sala permanece fechada...\n");
        } else {
            printf("\nOpcao invalida!\n");
        }
        printf("\n");

    } while (escolha != 0);

    return 0;
}
